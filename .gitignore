# Git
!.gitignore

# Release-signing private key. Never commit. Stays in CI secrets only.
verification/release-privkey.minisign
verification/*.minisign-private

# Explicitly tracked top-level docs.
!README.md
!LICENSE
!CONTRIBUTING.md
!ARCHITECTURE.md

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Rust
target/
**/target/
*.rlib
*.rmeta
# Cargo.lock — explicitly tracked. MIRA is a binary crate, so Cargo's
# own guidance is to commit it: CI builds with --locked then
# bit-for-bit reproduce the local build's dep graph. Library crates
# follow the opposite convention (don't commit), but that's not us.

# Node
node_modules/
jspm_packages/

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/


# Added by cargo

/target

# Signal-cli binaries and tarballs
signal-cli-*.tar.gz
signal-cli-client

# Claude session data
.claude/

# Exported docs
mira-export.md
